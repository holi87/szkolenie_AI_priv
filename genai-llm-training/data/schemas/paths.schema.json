{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "paths.schema.json",
  "title": "Macierz ścieżek S1/S2/S3",
  "description": "Kontrakt paths.json (issue #5). Gating ścieżka×moduł, progi, bramki zaliczenia.",
  "type": "object",
  "required": ["modules", "paths"],
  "properties": {
    "_meta": { "type": "object" },
    "statusLegend": { "type": "object" },
    "modules": {
      "type": "object",
      "required": ["M1", "M2", "M3", "M4", "M5", "M6", "M7", "M8", "M9", "M10", "M11", "M12"],
      "patternProperties": {
        "^M([1-9]|1[0-2])$": {
          "type": "object",
          "required": ["name", "timeFullMin", "questions"],
          "properties": {
            "name": { "type": "string" },
            "timeFullMin": { "type": "integer", "minimum": 1 },
            "questions": { "type": "integer", "minimum": 1 },
            "criticalQuestions": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": ["S1", "S2", "S3", "S4", "P1", "P2"],
      "patternProperties": {
        "^(S[1-4]|P[1-2])$": {
          "type": "object",
          "required": ["modules"],
          "properties": {
            "formative": { "type": "boolean", "description": "M15/ADR-0009: ścieżka FORMATYWNA (S4 Skala Holaka, P1 „AI w domu” #171) — diagnoza/rozwój + szkolenie, BEZ testu końcowego/progu/scoringu. Gdy true, pola test-owe (requiredModules/finalTestQuestions/dedicatedQuestionsMin/passThresholdPct/criticalQuestionsRequiredPct/practicalTasks/gates/attempts) są NIEwymagane — patrz conditional required (allOf/if/then/else) niżej. Gdy brak/false: ścieżka klasyczna z testem (else wymusza komplet pól; pokrycie M1..M12 dla poziomów S1..S3 egzekwuje validate.mjs — derive, nie schemat, bo P2 ma własny zestaw MB1..MB6)." },
            "level": { "type": "integer", "minimum": 1, "maximum": 3, "description": "#171: poziom ścieżki „AI z QA” (S1=1 Podstawowy, S2=2 Praktyk, S3=3 Inżynier). Ścieżki z level są grupowane w UI w JEDNĄ kartę z selektorem poziomu; dane/progres/scoring bez zmian (zero migracji)." },
            "bonus": { "type": "boolean", "description": "#171: ścieżka BONUSOWA (S4 Skala Holaka) — prezentowana poza siatką wyboru ścieżek (osobny pasek), nie konkuruje w pickerze. Wyłącznie warstwa prezentacji; id i progres bez zmian." },
            "modules": {
              "type": "object",
              "patternProperties": {
                "^M([1-9]|1[0-2]|SHO|SHP|SK[1-9]|B[1-6]|D[1-6])$": {
                  "type": "object",
                  "required": ["required", "variant"],
                  "properties": {
                    "required": { "type": "boolean" },
                    "variant": { "type": "string", "enum": ["full", "skrocony", "opcjonalny", "swiadomosciowy", "rozszerzony", "praktyczny", "diagnostyczny", "formatywny"] }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "requiredModules": { "type": "array", "items": { "type": "string", "pattern": "^M([1-9]|1[0-2]|B[1-6])$" } },
            "estContentTimeMin": { "type": "integer" },
            "estContentTimeNote": { "type": "string" },
            "finalTestQuestions": { "type": "integer", "minimum": 1 },
            "dedicatedQuestionsMin": { "type": "integer", "minimum": 0, "description": "M13/ADR-0006: minimalna liczba pytań z modułów DEDYKOWANYCH wymuszona w teście końcowym ścieżki (persona realnie różni się treścią testu — nie losuje całości z rdzenia)." },
            "passThresholdPct": { "type": "integer", "minimum": 0, "maximum": 100 },
            "criticalQuestionsRequiredPct": { "type": "integer", "minimum": 0, "maximum": 100 },
            "practicalTasks": { "type": "integer", "minimum": 0 },
            "extraPassConditions": { "type": "array", "items": { "type": "string" } },
            "gates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "type": "string", "enum": ["overallThreshold", "criticalQuestions", "practicalTask", "moduleMinScore"] },
                  "minPct": { "type": "number", "minimum": 0, "maximum": 100 },
                  "module": { "type": "string", "pattern": "^M([1-9]|1[0-2]|B[1-6])$" },
                  "rubric": { "type": "string" },
                  "minScore": { "type": "number", "minimum": 0 },
                  "maxScore": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false,
                "allOf": [
                  { "if": { "properties": { "type": { "const": "overallThreshold" } } },
                    "then": { "required": ["minPct"] } },
                  { "if": { "properties": { "type": { "const": "criticalQuestions" } } },
                    "then": { "required": ["module", "minPct"] } },
                  { "if": { "properties": { "type": { "const": "practicalTask" } } },
                    "then": { "required": ["rubric", "minScore"] } },
                  { "if": { "properties": { "type": { "const": "moduleMinScore" } } },
                    "then": { "required": ["module", "minPct", "rubric"] } }
                ]
              }
            },
            "attempts": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": { "required": ["formative"], "properties": { "formative": { "const": true } } },
              "then": {},
              "else": {
                "required": ["requiredModules", "finalTestQuestions", "dedicatedQuestionsMin", "passThresholdPct", "criticalQuestionsRequiredPct", "practicalTasks", "gates", "attempts"]
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
