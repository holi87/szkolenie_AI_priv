{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "modules-labels.schema.json",
  "title": "Etykiety modułów per-locale",
  "description": "Kontrakt data/<lang>/modules.labels.json — prose wyświetlana modułów, po ID (carve-out z modules.json, ADR-0004). Struktura/scoring single-source w data/modules.json.",
  "type": "object",
  "required": ["M1", "M2", "M3", "M4", "M5", "M6", "M7", "M8", "M9", "M10", "M11", "M12"],
  "patternProperties": {
    "^M([1-9]|1[0-2])$": {
      "type": "object",
      "required": ["name", "level", "interactiveElement", "keyConcepts", "learningOutcomes"],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "level": { "type": "string" },
        "interactiveElement": { "type": "string" },
        "keyConcepts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "learningOutcomes": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
