{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "modules.schema.json",
  "title": "Metadane modułów kursu",
  "description": "Kontrakt modules.json — kanoniczne metadane treści 12 modułów.",
  "type": "object",
  "required": ["modules"],
  "properties": {
    "_meta": { "type": "object" },
    "pillars": { "type": "object" },
    "modules": {
      "type": "array",
      "minItems": 12, "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "order", "name", "level", "timeFullMin", "pillar", "interactiveElement", "questionRange", "keyConcepts", "learningOutcomes"],
        "properties": {
          "id": { "type": "string", "pattern": "^M([1-9]|1[0-2])$" },
          "order": { "type": "integer", "minimum": 1, "maximum": 12 },
          "name": { "type": "string", "minLength": 3 },
          "level": { "type": "string" },
          "timeFullMin": { "type": "integer", "minimum": 1 },
          "pillar": { "type": "string", "enum": ["foundations_technical", "qa_practice", "security_governance"] },
          "interactiveElement": { "type": "string" },
          "questionRange": {
            "type": "object",
            "required": ["from", "to", "count"],
            "properties": {
              "from": { "type": "string", "pattern": "^Q[0-9]{3}$" },
              "to": { "type": "string", "pattern": "^Q[0-9]{3}$" },
              "count": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "criticalQuestions": { "type": "integer", "minimum": 0 },
          "keyConcepts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "learningOutcomes": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
