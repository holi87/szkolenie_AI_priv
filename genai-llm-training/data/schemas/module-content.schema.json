{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Treść modułu szkolenia (M4)",
  "description": "Treść narracyjna + config interakcji per moduł. Treść oddzielona od logiki (AGENTS). Interakcja: jeden z czterech typów (classify/rubric/tune/maturity-check; M14/ADR-0008). Wszystkie przykłady danych SYNTETYCZNE.",
  "type": "object",
  "required": ["module", "screens", "interaction", "summary"],
  "additionalProperties": false,
  "properties": {
    "_meta": { "type": "object" },
    "module": { "type": "string", "pattern": "^M([1-9]|1[0-2]|SH|SK[1-9])$" },
    "intro": { "type": "string" },
    "screens": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/screen" } },
    "interaction": { "$ref": "#/definitions/interaction" },
    "summary": { "$ref": "#/definitions/summary" }
  },
  "definitions": {
    "pathList": { "type": "array", "items": { "type": "string", "enum": ["S1", "S2", "S3"] } },
    "screen": {
      "type": "object",
      "required": ["id", "type", "blocks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["content", "decision", "summary"] },
        "onlyForPaths": { "$ref": "#/definitions/pathList" },
        "hideForPaths": { "$ref": "#/definitions/pathList" },
        "blocks": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/block" } }
      }
    },
    "block": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["paragraph", "list", "definition", "callout", "table", "diagram"] },
        "text": { "type": "string" },
        "ordered": { "type": "boolean" },
        "items": { "type": "array", "items": { "type": "string" } },
        "term": { "type": "string" },
        "original": { "type": "string" },
        "variant": { "type": "string", "enum": ["info", "warn", "safe"] },
        "title": { "type": "string" },
        "caption": { "type": "string" },
        "headers": { "type": "array", "items": { "type": "string" } },
        "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
        "textAlt": { "type": "string" },
        "ascii": { "type": "string" },
        "onlyForPaths": { "$ref": "#/definitions/pathList" },
        "hideForPaths": { "$ref": "#/definitions/pathList" }
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "paragraph" } } }, "then": { "required": ["text"] } },
        { "if": { "properties": { "kind": { "const": "list" } } }, "then": { "required": ["items"] } },
        { "if": { "properties": { "kind": { "const": "definition" } } }, "then": { "required": ["term", "text"] } },
        { "if": { "properties": { "kind": { "const": "callout" } } }, "then": { "required": ["text"] } },
        { "if": { "properties": { "kind": { "const": "table" } } }, "then": { "required": ["headers", "rows", "textAlt"] } },
        { "if": { "properties": { "kind": { "const": "diagram" } } }, "then": { "required": ["textAlt"] } }
      ]
    },
    "interaction": {
      "type": "object",
      "required": ["kind", "title"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["classify", "rubric", "tune", "maturity-check"] },
        "id": { "type": "string" },
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "passPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "categories": {
          "type": "array", "minItems": 2,
          "items": { "type": "object", "required": ["id", "label"], "additionalProperties": false,
            "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "desc": { "type": "string" } } }
        },
        "items": {
          "type": "array", "minItems": 1,
          "items": { "type": "object", "required": ["id", "text", "correctCategory"], "additionalProperties": false,
            "properties": { "id": { "type": "string" }, "text": { "type": "string" }, "correctCategory": { "type": "string" }, "rationale": { "type": "string" } } }
        },
        "scaleMax": { "type": "number", "minimum": 1 },
        "passThreshold": { "type": "number", "minimum": 0 },
        "rubricId": { "type": "string" },
        "recordsPractical": { "type": "boolean" },
        "paths": { "$ref": "#/definitions/pathList" },
        "criteria": {
          "type": "array", "minItems": 1,
          "items": { "type": "object", "required": ["id", "name", "options", "correctOptionIds"], "additionalProperties": false,
            "properties": {
              "id": { "type": "string" }, "name": { "type": "string" }, "prompt": { "type": "string" },
              "points": { "type": "number", "minimum": 0 }, "hint": { "type": "string" },
              "options": { "type": "array", "minItems": 2, "items": { "type": "object", "required": ["id", "text"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "text": { "type": "string" } } } },
              "correctOptionIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            } }
        },
        "outputLabel": { "type": "string" },
        "controls": {
          "type": "array", "minItems": 1,
          "items": { "type": "object", "required": ["id", "label", "levels"], "additionalProperties": false,
            "properties": {
              "id": { "type": "string" }, "label": { "type": "string" },
              "levels": { "type": "array", "minItems": 2, "items": { "type": "object", "required": ["label", "effect"], "additionalProperties": false, "properties": { "value": { "type": "string" }, "label": { "type": "string" }, "effect": { "type": "string" } } } }
            } }
        },
        "checkpoint": {
          "type": "object", "required": ["prompt", "type", "options", "correct"], "additionalProperties": false,
          "properties": {
            "prompt": { "type": "string" },
            "type": { "type": "string", "enum": ["single_choice", "multiple_choice"] },
            "options": { "type": "array", "minItems": 2, "items": { "type": "object", "required": ["id", "text"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "text": { "type": "string" } } } },
            "correct": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "feedbackCorrect": { "type": "string" },
            "feedbackIncorrect": { "type": "string" }
          }
        },
        "scales": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "max", "statements", "bands"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "intro": { "type": "string" },
              "max": { "type": "integer", "minimum": 1 },
              "statements": {
                "type": "array", "minItems": 1,
                "items": { "type": "object", "required": ["id", "text"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "text": { "type": "string" } } }
              },
              "bands": {
                "type": "array", "minItems": 1,
                "items": { "type": "object", "required": ["min", "max", "label", "advice"], "additionalProperties": false, "properties": { "min": { "type": "integer", "minimum": 0 }, "max": { "type": "integer", "minimum": 0 }, "label": { "type": "string" }, "advice": { "type": "string" } } }
              }
            }
          }
        }
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "classify" } } }, "then": { "required": ["categories", "items"] } },
        { "if": { "properties": { "kind": { "const": "rubric" } } }, "then": { "required": ["criteria"] } },
        { "if": { "properties": { "kind": { "const": "tune" } } }, "then": { "required": ["controls", "checkpoint"] } },
        { "if": { "properties": { "kind": { "const": "maturity-check" } } }, "then": { "required": ["scales"] } }
      ]
    },
    "summary": {
      "type": "object",
      "required": ["points", "nextStep"],
      "additionalProperties": false,
      "properties": {
        "points": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "checklist": { "type": "array", "items": { "type": "string" } },
        "checklistTitle": { "type": "string" },
        "nextStep": { "type": "string" }
      }
    }
  }
}
