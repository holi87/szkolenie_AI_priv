{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scenarios.schema.json",
  "title": "Syntetyczne scenariusze szkoleniowe",
  "description": "Kontrakt scenarios.json (issue #8). Wszystkie dane syntetyczne.",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "_meta": { "type": "object" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "modules", "paths", "competency", "data"],
        "properties": {
          "id": { "type": "string", "pattern": "^SC-[A-Z]+-[0-9]{2}$" },
          "title": { "type": "string", "minLength": 3 },
          "modules": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^M([1-9]|1[0-2])$" } },
          "paths": { "type": "array", "minItems": 1, "items": { "type": "string", "enum": ["S1", "S2", "S3"] } },
          "competency": { "type": "string" },
          "usedBy": { "type": "array", "items": { "type": "string" } },
          "data": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
