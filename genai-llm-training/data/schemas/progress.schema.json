{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "progress.schema.json",
  "title": "Model progresu uczestnika",
  "description": "Kontrakt progresu zapisywanego lokalnie (localStorage, MVP) i transferowalnego do zewnętrznego backendu po pilotażu (issue #2/ADR-0001). Definiuje kształt, nie implementację — progress-store (#16) i certyfikat (#19) konsumują ten kształt; backend wyników może przyjąć ten sam payload.",
  "type": "object",
  "required": ["version", "path", "modules", "updatedAt"],
  "properties": {
    "version": { "type": "string", "description": "Wersja schematu progresu (semver)" },
    "participant": {
      "type": "object",
      "description": "Opcjonalne; anonimowość vs logowanie zależy od decyzji P3 (otwarte).",
      "properties": {
        "displayName": { "type": "string" },
        "anonymousId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "path": { "type": "string", "enum": ["S1", "S2", "S3"] },
    "modules": {
      "type": "object",
      "description": "Stan per moduł (klucz = id modułu).",
      "patternProperties": {
        "^M([1-9]|1[0-2])$": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["locked", "available", "in_progress", "completed"] },
            "lastScreen": { "type": "string" },
            "timeSpentSec": { "type": "integer", "minimum": 0, "description": "Realny czas w module (wymagania/10: dane progresu = moduł, status, czas, ścieżka; KPI Time to complete)." },
            "inlineQuizScorePct": { "type": "number", "minimum": 0, "maximum": 100 },
            "quizResults": {
              "type": "array",
              "description": "Wyniki quizu inline per pytanie (wymagania/10: ID pytania, wynik, próba, feedback) — pozwala odtworzyć próby, pokazać poprzedni feedback i audytować słabe pytania.",
              "items": {
                "type": "object",
                "required": ["questionId", "correct", "attempt"],
                "properties": {
                  "questionId": { "type": "string", "pattern": "^Q[0-9]{3}$" },
                  "correct": { "type": "boolean" },
                  "attempt": { "type": "integer", "minimum": 1 },
                  "scoreAwarded": { "type": "number", "minimum": 0 },
                  "feedbackShown": { "type": "boolean" },
                  "feedback": { "type": "string", "description": "Treść feedbacku pokazanego uczestnikowi (wymagania/10: ID pytania, wynik, próba, feedback)." },
                  "answeredAt": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "interaction": {
              "type": "object",
              "description": "Wynik interakcji modułowej (M4): klasyfikator/rubryka/strojenie — feedback i zapis wyniku (#20).",
              "required": ["kind", "score", "max"],
              "properties": {
                "kind": { "type": "string", "enum": ["classify", "rubric", "tune"] },
                "score": { "type": "number", "minimum": 0 },
                "max": { "type": "number", "minimum": 0 },
                "pct": { "type": "number", "minimum": 0, "maximum": 100 },
                "passed": { "type": "boolean" },
                "completedAt": { "type": "string" }
              },
              "additionalProperties": false
            },
            "completedAt": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "finalTest": {
      "type": "object",
      "properties": {
        "attempts": { "type": "integer", "minimum": 0 },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "lastScorePct": { "type": "number", "minimum": 0, "maximum": 100 },
        "criticalQuestionsPassed": { "type": "boolean" },
        "passed": { "type": "boolean" },
        "weakModules": { "type": "array", "items": { "type": "string", "pattern": "^M([1-9]|1[0-2])$" } },
        "questionResults": {
          "type": "array",
          "description": "Per-pytanie testu końcowego (anonimowo) — sygnał kalibracyjny #28; obejmuje pytania spoza puli quizu inline (w tym golden).",
          "items": {
            "type": "object",
            "required": ["questionId", "correct"],
            "properties": {
              "questionId": { "type": "string", "pattern": "^Q[0-9]{3}$" },
              "module": { "type": "string", "pattern": "^M([1-9]|1[0-2])$" },
              "correct": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "practicalTasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rubric", "score"],
        "properties": {
          "rubric": { "type": "string" },
          "score": { "type": "number", "minimum": 0 },
          "maxScore": { "type": "number", "minimum": 0 },
          "passed": { "type": "boolean" },
          "comments": { "type": "string", "description": "Komentarz oceniającego (wymagania/10: zadania praktyczne = ocena 0-5, komentarze, obszary poprawy)." },
          "areasForImprovement": { "type": "array", "items": { "type": "string" }, "description": "Obszary poprawy (wymagania/10)." }
        },
        "additionalProperties": false
      }
    },
    "certificate": {
      "type": "object",
      "properties": {
        "issued": { "type": "boolean" },
        "completionId": { "type": "string" },
        "scorePct": { "type": "number" },
        "issuedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "scoreWeights": {
      "type": "object",
      "description": "Wagi wyniku ścieżki (zgodne z macierzą): quiz inline 30% / test końcowy 60% / zadanie praktyczne 10%.",
      "properties": {
        "inlineQuiz": { "type": "number" },
        "finalTest": { "type": "number" },
        "practicalTask": { "type": "number" }
      },
      "additionalProperties": false
    },
    "updatedAt": { "type": "string", "description": "ISO 8601 timestamp ostatniej aktualizacji" }
  },
  "additionalProperties": false
}
